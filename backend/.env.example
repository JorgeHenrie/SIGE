# ============================================================
# SIGE - Configurações de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA envie o .env para o repositório.
# ============================================================

APP_NOME=SIGE
APP_AMBIENTE=development
APP_URL=http://localhost:8000
APP_DEBUG=true

# Banco de dados
DB_HOST=localhost
DB_PORT=5432
DB_NOME=sige_db
DB_SCHEMA=sige
DB_USUARIO=postgres
DB_SENHA=

# Segurança - CPF
# Gere chaves seguras: php -r "echo bin2hex(random_bytes(32));"
APP_CPF_HMAC_KEY=
APP_CPF_ENCRYPT_KEY=

# CORS - origem permitida do frontend
CORS_ORIGIN=http://localhost:5173

# Roteirizacao - geocoding
ROUTE_GEOCODING_PROVIDER=nominatim
ROUTE_GEOCODING_USER_AGENT="SIGE-Roteirizacao/1.0 (https://seu-dominio-ou-contato)"
ROUTE_GEOCODING_TIMEOUT=3
ROUTE_MAX_VISITA_DISTANCIA_KM=120
